#!/bin/bash

set -euo pipefail

DOCKER_PROXY="${DOCKER_PROXY:-http://172.17.0.1:7897/}"

proxy_args=(
    --build-arg HTTP_PROXY="${DOCKER_PROXY}"
    --build-arg HTTPS_PROXY="${DOCKER_PROXY}"
)

echo "==> Building dogbot-base:arm64"
docker buildx build . --platform linux/arm64 --target dogbot-base -t dogbot-base:arm64 \
    "${proxy_args[@]}" --load

echo "==> Building dogbot-develop-full:latest"
docker buildx build . --platform linux/amd64 --target dogbot-develop-full \
    --build-arg SYSROOT_IMAGE_ARM64=dogbot-base:arm64 \
    "${proxy_args[@]}" --load

echo "==> Building dogbot-runtime:arm64"
docker buildx build . --platform linux/arm64 --target dogbot-runtime -t dogbot-runtime:arm64 \
    "${proxy_args[@]}" --load

echo "==> Done"

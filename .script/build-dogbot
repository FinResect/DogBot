#!/bin/bash

set -euo pipefail

: "${DOGBOT_PATH:=/workspaces/DogBot}"

target_arch=arm64
colcon_args=("$@")

case "${target_arch}" in
arm64)
    target_triplet="aarch64-linux-gnu"
    ;;
amd64)
    target_triplet="x86_64-linux-gnu"
    ;;
*)
    echo "> ERROR: Unsupported target arch '${target_arch}'."
    exit 1
    ;;
esac

workspace="${DOGBOT_PATH}/ros2_ws"
sysroot="${DOGBOT_SYSROOT:-/opt/sysroots/${target_arch}}"

if [[ ! -d "${workspace}" ]]; then
    echo "> ERROR: Workspace not found: ${workspace}"
    exit 1
fi

if [[ ! -d "${sysroot}" ]]; then
    echo "> ERROR: Sysroot not found: ${sysroot}"
    exit 1
fi

if ! command -v "${target_triplet}-gcc" &>/dev/null; then
    echo "> ERROR: Missing cross compiler: ${target_triplet}-gcc"
    exit 1
fi

if ! command -v "${target_triplet}-g++" &>/dev/null; then
    echo "> ERROR: Missing cross compiler: ${target_triplet}-g++"
    exit 1
fi

unset AMENT_PREFIX_PATH
unset CMAKE_PREFIX_PATH
unset COLCON_PREFIX_PATH
unset AMENT_CURRENT_PREFIX
unset PKG_CONFIG_PATH
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_SYSROOT_DIR
unset ROS_PACKAGE_PATH
unset PYTHONPATH
unset PYTHONHOME
unset LD_LIBRARY_PATH
unset LIBRARY_PATH
unset CPATH
unset C_INCLUDE_PATH
unset CPLUS_INCLUDE_PATH
unset CFLAGS
unset CXXFLAGS
unset CPPFLAGS
unset LDFLAGS
unset CMAKE_INCLUDE_PATH
unset CMAKE_LIBRARY_PATH
unset CMAKE_PROGRAM_PATH
unset CMAKE_TOOLCHAIN_FILE
unset CMAKE_GENERATOR

source /opt/ros/humble/setup.bash

export DOGBOT_TARGET_ARCH="${target_arch}"
export DOGBOT_TARGET_TRIPLET="${target_triplet}"
export DOGBOT_SYSROOT="${sysroot}"

export CC="$(command -v "${target_triplet}-gcc")"
export CXX="$(command -v "${target_triplet}-g++")"

export CMAKE_PREFIX_PATH="${DOGBOT_SYSROOT}/opt/ros/humble:${DOGBOT_SYSROOT}/usr/local:${DOGBOT_SYSROOT}/usr"
export AMENT_PREFIX_PATH="${DOGBOT_SYSROOT}/opt/ros/humble"
export COLCON_PREFIX_PATH="${DOGBOT_SYSROOT}/opt/ros/humble"
export PKG_CONFIG_PATH=""

export PKG_CONFIG_SYSROOT_DIR="${DOGBOT_SYSROOT}"
export PKG_CONFIG_LIBDIR="${DOGBOT_SYSROOT}/usr/local/lib/${DOGBOT_TARGET_TRIPLET}/pkgconfig:${DOGBOT_SYSROOT}/usr/local/lib/pkgconfig:${DOGBOT_SYSROOT}/usr/local/share/pkgconfig:${DOGBOT_SYSROOT}/usr/lib/${DOGBOT_TARGET_TRIPLET}/pkgconfig:${DOGBOT_SYSROOT}/usr/lib/pkgconfig:${DOGBOT_SYSROOT}/usr/share/pkgconfig:${DOGBOT_SYSROOT}/lib/${DOGBOT_TARGET_TRIPLET}/pkgconfig:${DOGBOT_SYSROOT}/lib/pkgconfig:${DOGBOT_SYSROOT}/opt/ros/humble/lib/${DOGBOT_TARGET_TRIPLET}/pkgconfig:${DOGBOT_SYSROOT}/opt/ros/humble/lib/pkgconfig:${DOGBOT_SYSROOT}/opt/ros/humble/share/pkgconfig"

cd "${workspace}"

build_base="build-cross-${DOGBOT_TARGET_ARCH}"
install_base="install-cross-${DOGBOT_TARGET_ARCH}"
log_base="log-cross-${DOGBOT_TARGET_ARCH}"

CLICOLOR_FORCE=1 NINJA_STATUS="" \
    colcon \
    --log-base "${log_base}" \
    build \
    --merge-install \
    --build-base "${build_base}" \
    --install-base "${install_base}" \
    "${colcon_args[@]}" \
    --cmake-args \
    -DCMAKE_TOOLCHAIN_FILE="${workspace}/toolchain.cmake" \
    -DDOGBOT_TARGET_ARCH="${DOGBOT_TARGET_ARCH}" \
    -DDOGBOT_SYSROOT="${DOGBOT_SYSROOT}" \
    -DDOGBOT_TARGET_TRIPLET="${DOGBOT_TARGET_TRIPLET}"

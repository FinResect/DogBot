// For format details, see https://aka.ms/devcontainer.json.
{
    "name": "DogBot-develop",
    "build": {
        "context": "..",
        "dockerfile": "../Dockerfile",
        "target": "dogbot-develop"
    },
    "privileged": true,

    "runArgs": [
        "--net=host",
        "--ipc=host",
        // "--gpus=all",
        "-e", "DISPLAY=${localEnv:DISPLAY}",
        // "-e", "NVIDIA_DRIVER_CAPABILITIES=all",
        // "-e", "NVIDIA_VISIBLE_DEVICES=all",
        "-v", "/tmp/.X11-unix:/tmp/.X11-unix:rw"
    ],

    "containerEnv": {
        "XDG_RUNTIME_DIR": "/tmp/runtime-root"
    },

    "mounts": [
        "source=${localEnv:HOME}/.gitconfig,target=/tmp/.host_gitconfig,type=bind,ro"
    ],

    "postCreateCommand": "bash -c 'if [ -f /tmp/.host_gitconfig ]; then cp /tmp/.host_gitconfig ~/.gitconfig && chmod 644 ~/.gitconfig; fi && (chmod +x /workspaces/DogBot/.script/* || true)'",

    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "zsh"
            },
            "extensions": [
                "llvm-vs-code-extensions.vscode-clangd",
                "ms-python.vscode-pylance",
                "ms-python.python",
                "ms-python.debugpy",
                "twxs.cmake",
                "streetsidesoftware.code-spell-checker",
                "mhutchie.git-graph",
                "GitHub.copilot"
            ]
        }
    }
}
